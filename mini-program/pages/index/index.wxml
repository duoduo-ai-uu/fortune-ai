<!-- Labubu 算命小程序 - 精致版 -->
<view class="page">
  <!-- 星空背景 -->
  <view class="stars-container">
    <view class="star" wx:for="{{stars}}" wx:key="index" 
          style="left: {{item.x}}%; top: {{item.y}}%; animation-delay: {{item.delay}}s; width: {{item.size}}rpx; height: {{item.size}}rpx;"></view>
    <!-- 流星 -->
    <view class="shooting-star" style="top: 10%; left: 20%; animation-delay: 0s;"></view>
    <view class="shooting-star" style="top: 25%; left: 60%; animation-delay: 1.5s;"></view>
  </view>

  <!-- 顶部 Labubu 区域 -->
  <view class="labubu-header">
    <view class="labubu-avatar labubu-avatar">🐰</view>
    <view class="labubu-info">
      <view class="labubu-name">Labubu</view>
      <view class="labubu-desc">神秘指引 · 每日运势</view>
    </view>
  </view>

  <!-- 类型选择器 -->
  <view class="type-selector">
    <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{fortuneTypes}}" range-key="name">
      <view class="picker-btn">
        <text>{{fortuneTypes[typeIndex].icon}}</text>
        <text>{{fortuneTypes[typeIndex].name}}</text>
        <text>▼</text>
      </view>
    </picker>
  </view>

  <!-- 聊天区域 -->
  <view class="chat-box">
    <scroll-view class="messages" scroll-y="true" enhanced="true" show-scrollbar="false">
      <block wx:for="{{messages}}" wx:key="index">
        <!-- 用户消息 -->
        <view class="message user" wx:if="{{item.role === 'user'}}">
          <view class="message-content">{{item.content}}</view>
          <view class="message-avatar"></view>
        </view>
        
        <!-- AI普通消息 -->
        <view class="message assistant" wx:elif="{{item.role === 'assistant' && !item.isFortune}}">
          <view class="message-avatar">🔮</view>
          <view class="message-content">{{item.content}}</view>
        </view>
        
        <!-- 运势卡片 -->
        <view class="message assistant" wx:elif="{{item.isFortune}}">
          <view class="message-avatar">🔮</view>
          <view class="fortune-card" style="background: {{item.cardColor || 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'}}">
            <view class="fortune-card-header">
              <text class="fortune-card-icon">{{item.icon}}</text>
              <text class="fortune-card-title">{{item.typeName}}</text>
              <button class="share-btn" catchtap="onShareAppMessage" data-content="{{item.content}}">📤</button>
            </view>
            <view class="fortune-card-content">{{item.content}}</view>
            <view class="fortune-card-footer">
              <view class="fortune-card-tag luck-tag">✨ 幸运指数: {{item.luck}}%</view>
              <view class="fortune-card-tag">{{item.tip}}</view>
            </view>
          </view>
        </view>
      </block>
      
      <!-- Loading -->
      <view class="message assistant" wx:if="{{loading}}">
        <view class="message-avatar">🔮</view>
        <view class="message-content loading">
          <text>神秘力量感应中</text>
          <view class="loading-dots"></view>
        </view>
      </view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="input-row safe-area-bottom">
      <input class="input" placeholder="输入你想问的问题..." placeholder-class="input-placeholder" value="{{inputValue}}" bindinput="onInput" confirm-type="send" bindconfirm="onSend" />
      <button class="send-btn" bindtap="onSend" disabled="{{loading || !inputValue}}">
        {{loading ? '...' : '问一问'}}
      </button>
    </view>
  </view>
</view>
